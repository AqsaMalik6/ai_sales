{
    "manifest_version": 3,
    "name": "LinkedIn Sales Intelligence",
    "version": "1.0",
    "description": "Sales prospecting tool for LinkedIn",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*",
        "https://api.apollo.io/*",
        "http://localhost:3000/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/in/*",
                "http://localhost:3000/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_title": "LinkedIn Sales"
    }
}